[SERVICE]
    Flush        1
    Daemon       Off
    Log_Level    info
    Parsers_File parsers.conf

[INPUT]
    Name              systemd
    Tag               fb_tag
    Path              /var/log/journal
    DB                /var/log/journal/journal-forwarder.db
    Read_From_Tail    False
    Systemd_Filter    _TRANSPORT=journal

[FILTER]
    Name                modify
    Match               *
    Rename            _HOSTNAME            hostname
    Rename            _SYSTEMD_UNIT        unit
    Rename            _SYSTEMD_USER_UNIT   user_unit
    Rename            __REALTIME_TIMESTAMP timestamp_raw
    Rename            MESSAGE              raw_message
    Rename            PRIORITY             syslog_priority

[OUTPUT]
    Name                gelf
    Match               *
    Host                {{ graylog_gelf_host }}
    Port                {{ graylog_gelf_port }}
    Mode                {{ graylog_gelf_mode }}
    Workers             {{ graylog_fluent_bit_workers }}
    Gelf_Host_Key       hostname
    Gelf_Short_Message_Key message
    Gelf_Level_Key      priority
    Gelf_Tag_Key        fb_tag
